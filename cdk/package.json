{
  "name": "anthropic-proxy-cdk",
  "version": "1.0.0",
  "description": "CDK infrastructure for Anthropic-Bedrock API Proxy",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:dev": "cdk deploy --all --require-approval never -c environment=dev",
    "deploy:prod": "cdk deploy --all --require-approval never -c environment=prod",
    "destroy": "cdk destroy --all",
    "diff": "cdk diff"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "aws-cdk": "^2.1114.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.246.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  },
  "overrides": {
    "minimatch": ">=3.1.4",
    "flatted": ">=3.4.2",
    "lodash": ">=4.17.23",
    "@smithy/config-resolver": ">=4.4.0",
    "esbuild": ">=0.25.0"
  }
}
